        {
            "_id": 2,
            "theme_key": "ink_and_ember_dark",
            "theme_label": {
                "eng": {
                    "text": "Ink & Ember (Dark)"
                },
                "spa": {
                    "text": "Tinta y Brasa (Oscuro)"
                },
                "fil": {
                    "text": "Tinta at Baga (Madilim)"
                },
                "kor": {
                    "text": "잉크와 불씨 (다크)"
                }
            },
            "theme_description": {
                "eng": {
                    "text": "Ink & Ember (Dark) places night black and graphite surfaces at the center, then uses electric blue, ember glow, and fresh green to create contrast, movement, and warmth. The palette gives the interface a premium nocturnal tone while keeping actions, links, and status cues easy to notice. It allows an application to feel bold and immersive while remaining readable, practical, and visually disciplined."
                },
                "spa": {
                    "text": "Tinta y Brasa (Oscuro) coloca el negro noche y las superficies grafito en el centro, y usa azul eléctrico, brillo brasa y verde fresco para crear contraste, movimiento y calidez. La paleta da a la interfaz un tono nocturno y premium, manteniendo las acciones, enlaces y señales de estado fáciles de identificar. Permite que una aplicación se sienta audaz e inmersiva sin perder legibilidad, practicidad ni disciplina visual."
                },
                "fil": {
                    "text": "Inilalagay ng Tinta at Baga (Madilim) ang night black at graphite surfaces sa sentro, habang ginagamit ang electric blue, ember glow, at fresh green para sa contrast, galaw, at init. Binibigyan ng palette ang interface ng premium na nocturnal tone habang nananatiling madaling makita ang actions, links, at status cues. Pinapayagan nitong magmukhang matapang at immersive ang application habang nananatiling nababasa, praktikal, at maayos ang visual discipline."
                },
                "kor": {
                    "text": "잉크와 불씨 (다크)는 나이트 블랙과 그래파이트 표면을 중심에 두고, 일렉트릭 블루, 엠버 글로우, 프레시 그린으로 대비와 움직임, 따뜻함을 만듭니다. 이 팔레트는 인터페이스에 프리미엄 야간 톤을 주면서도 동작, 링크, 상태 표시가 쉽게 보이도록 합니다. 애플리케이션이 대담하고 몰입감 있게 느껴지면서도 읽기 쉽고 실용적이며 시각적으로 정돈되도록 합니다."
                }
            },
