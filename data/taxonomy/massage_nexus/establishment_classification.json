            {
                "option_code": "A",
                "option_label": "Premium",
                "option_description": "Clearly upscale spa experience above ordinary professional standards."
            },
            {
                "option_code": "B",
                "option_label": "Standard",
                "option_description": "Dependable mainstream professional spa with appropriate cleanliness, safety, privacy, and organization."
            },
            {
                "option_code": "C",
                "option_label": "Budget",
                "option_description": "Affordable spa with simpler facilities and presentation but normal expectations for safety, respect, honesty, and value."
            },
            {
                "option_code": "D",
                "option_label": "Basic",
                "option_description": "Minimal or entry-level establishment focused on essential, short, shared, or limited-amenity service."
            }
